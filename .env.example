# Example environment variables for Gym Assistant System
# Copy this file to `.env` and fill with real values locally.

# Django
DJANGO_SECRET_KEY=replace_with_a_strong_secret_key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# AI service keys (do NOT commit real keys)
# Provide at least one GEMINI or OPENROUTER key depending on provider
GEMINI_KEY_1=
#GEMINI_KEY_2=
#GEMINI_KEY_3=

OPENROUTER_KEY_1=
#OPENROUTER_KEY_2=

# Optional provider/model overrides
#GENAI_MODEL=models/gemini-2.0-flash
#OPENROUTER_MODEL=openrouter/auto

# AI/chat settings
GENAI_MAX_CHAT_HISTORY=4

# Database (optional) - default uses sqlite
#DATABASE_URL=sqlite:///db.sqlite3

# Other secrets
#SENTRY_DSN=
